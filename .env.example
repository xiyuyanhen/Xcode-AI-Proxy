# Xcode AI Proxy Python 版本环境变量配置
# 复制此文件为 .env 并填入真实的 API 密钥

# ===================
# API 密钥配置
# ===================

# 智谱AI GLM-4.5 模型 API 密钥
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Kimi AI API 密钥
# 获取地址: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek API 密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问（阿里云百炼 / DashScope）API 密钥
# 获取地址: https://bailian.console.aliyun.com/ 或 https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Aihubmix API 密钥（可选）
# 获取地址: https://aihubmix.com/token
# AIHUBMIX_API_KEY=your_aihubmix_api_key_here
# Aihubmix API Base URL（可选，默认 https://aihubmix.com/v1）
# 注意：不要再额外拼 /models 或 /chat/completions，代码会自动追加
# AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# 启动拉取模型列表失败时的兜底模型 id 列表（逗号分隔，可选）
# 例如：gpt-4o-mini,gpt-4o-search-preview
# AIHUBMIX_MODELS_FALLBACK=

# Ollama（本地可选，显式设置才启用）
# 设置后代理启动时会请求 GET {OLLAMA_BASE_URL}/api/tags 拉取模型列表并暴露在 /v1/models
# 示例: http://localhost:11434 或 http://192.168.1.70:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama Cloud（云端可选，与本地 OLLAMA_BASE_URL 相互独立）
# 显式设置 OLLAMA_CLOUD_API_KEY 才启用；Base URL 默认 https://ollama.com，可用 OLLAMA_CLOUD_BASE_URL 覆盖
# API Key 获取: https://ollama.com/settings/keys
# OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# 拉取 /api/tags 失败时的兜底模型列表（逗号分隔），例如: llama3,qwen3
# OLLAMA_CLOUD_MODELS=llama3,qwen3

# ===================
# 服务器配置
# ===================

# 服务器端口 (默认: 3000)
PORT=8899

# 服务器主机 (默认: 0.0.0.0)
HOST=0.0.0.0

# ===================
# 重试配置
# ===================

# API 请求重试次数 (默认: 3)
MAX_RETRIES=3

# 重试延迟基数，单位毫秒 (默认: 1000)
# 实际延迟 = RETRY_DELAY * 重试次数
RETRY_DELAY=1000

# 请求超时时间，单位毫秒 (默认: 60000)
REQUEST_TIMEOUT=60000
